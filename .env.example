# PolitiCheck - variables de entorno
# Copia este archivo a .env y completa con tus credenciales reales.

# Anthropic API key - REQUERIDO
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# HuggingFace token - OPCIONAL
# Mejora la velocidad de descarga inicial de los modelos de faster-whisper.
# Obtener en: https://huggingface.co/settings/tokens (read-only es suficiente).
# HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
